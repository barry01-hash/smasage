# Environment Variables for Smasage Notification System

## Backend (Agent)
# Anthropic API key for Claude-based message generation
ANTHROPIC_API_KEY=sk-ant-xxxxx

# WebSocket Notification Server Port
NOTIFICATION_PORT=3001

# Soroban RPC endpoint (optional, for on-chain balance reading)
SOROBAN_RPC_URL=https://soroban-test.stellar.org

# Smasage contract ID on Stellar (optional, for balance reading)
SMASAGE_CONTRACT_ID=xxxxx

## Frontend
# WebSocket server URL (defaults to ws://localhost:3001 if not set)
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Optional: Feature flags
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_PROACTIVE_NUDGES=true
